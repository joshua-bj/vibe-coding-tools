# WeChat Configuration
# Get these from https://mp.weixin.qq.com

# Your WeChat Official Account AppID
WECHAT_APP_ID=your_app_id_here

# Your WeChat Official Account AppSecret
WECHAT_APP_SECRET=your_app_secret_here

# HTTP Port (default: 3000) - used for HTTP->HTTPS redirect when HTTPS is enabled
PORT=3000

# HTTPS Port (default: 443)
HTTPS_PORT=443

# Enable HTTPS (default: true)
# Set to 'false' to disable HTTPS and run HTTP only
ENABLE_HTTPS=true
